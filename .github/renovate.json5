{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'helpers:pinGitHubActionDigestsToSemver'
  ],
  prConcurrentLimit: 0,
  prHourlyLimit: 0,
  packageRules: [
    {
      matchManagers: ['gradle', 'gradle-wrapper'],
      allowedVersions: '!/SNAPSHOT|snapshot|dev|nightly/',
    },
  ],
}
